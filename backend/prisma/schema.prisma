generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model OAToken {
  id           String   @id
  accessToken  String
  refreshToken String
  expiresAt    DateTime @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("oa_tokens")
}

model Article {
  id           String   @id
  title        String
  description  String?
  content      String?
  thumbnailUrl String?
  category     String   @default("Tin tức") @db.VarChar(50)
  publishedAt  DateTime @db.Timestamptz(6)
  author       String?  @default("Admin") @db.VarChar(100)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([publishedAt(sort: Desc)])
  @@map("articles")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model bookings {
  id              String        @id
  code            String        @unique @db.VarChar(20)
  userId          String
  field           BookingField
  preferredDate   DateTime      @db.Timestamptz(6)
  preferredTime   String        @db.VarChar(5)
  confirmedDate   DateTime?     @db.Timestamptz(6)
  confirmedTime   String?       @db.VarChar(5)
  description     String
  contactName     String        @db.VarChar(100)
  status          BookingStatus @default(PENDING)
  rejectionReason String?
  rescheduledNote String?
  reminder24hSent Boolean       @default(false)
  reminder1hSent  Boolean       @default(false)
  oaMessageId     String?
  createdAt       DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime      @default(now()) @db.Timestamptz(6)
  users           users         @relation(fields: [userId], references: [id])

  @@index([createdAt(sort: Desc)])
  @@index([status])
  @@index([userId])
  @@index([userId, status])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model feedbacks {
  id          String           @id
  code        String           @unique @db.VarChar(20)
  userId      String
  title       String           @db.VarChar(100)
  category    FeedbackCategory
  description String
  imageUrls   String[]         @default([])
  latitude    Float?
  longitude   Float?
  address     String?
  status      FeedbackStatus   @default(PENDING)
  response    String?
  respondedAt DateTime?        @db.Timestamptz(6)
  oaMessageId String?
  createdAt   DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime         @default(now()) @db.Timestamptz(6)
  users       users            @relation(fields: [userId], references: [id])

  @@index([createdAt(sort: Desc)])
  @@index([status])
  @@index([userId])
  @@index([userId, status])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model ratings {
  id              String   @id
  userId          String
  procedure       String   @db.VarChar(100)
  attitudeScore   Int      @db.SmallInt
  timelinessScore Int      @db.SmallInt
  outcomeScore    Int      @db.SmallInt
  averageScore    Decimal  @db.Decimal(3, 1)
  comment         String?
  alertSent       Boolean  @default(false)
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  users           users    @relation(fields: [userId], references: [id])

  @@index([averageScore], map: "ratings_avgScore_idx")
  @@index([createdAt(sort: Desc)])
  @@index([userId])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model users {
  id          String      @id
  zaloId      String      @unique @db.VarChar(64)
  displayName String      @db.VarChar(255)
  phoneToken  String?
  createdAt   DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime    @default(now()) @db.Timestamptz(6)
  bookings    bookings[]
  feedbacks   feedbacks[]
  ratings     ratings[]

  @@index([createdAt(sort: Desc)])
  @@index([zaloId])
}

enum FeedbackStatus {
  PENDING
  PROCESSING
  TRANSFERRED
  RESOLVED
}

enum FeedbackCategory {
  HA_TANG
  VE_SINH
  TRAT_TU
  AN_NINH
  KHAC
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  RESCHEDULED
  COMPLETED
  CANCELLED
}

enum BookingField {
  HO_TICH
  CU_TRU
  CHUNG_THUC
  DAT_DAI
  XA_HOI
  KHAC
}
